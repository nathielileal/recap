{
  "expo": {
    "name": "RECAP",
    "slug": "recap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/recap-logo.png",
    "scheme": "recap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.recap"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/recap-logo.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "expo-static",
      "favicon": "./assets/images/recap-logo.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/recap-logo.png",
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      "expo-font"
    ]
  }
}
